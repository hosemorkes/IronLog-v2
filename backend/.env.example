# ─────────────────────────────────────────────
# IronLog API — переменные окружения для backend/api
#
# Скопируй в backend/.env (не коммитить секреты).
# Для Docker Compose см. также корневой .env.example: пароли для postgres/redis/rabbitmq/minio
# подставляет compose при сборке переменной ${VAR}. Сервис api в docker-compose.yml
# дополнительно задаёт через environment: DATABASE_URL, REDIS_URL, RABBITMQ_URL и MinIO*.
# ─────────────────────────────────────────────

# ── То же самое использует pydantic Settings (backend/core/config.py) ──────

DATABASE_URL=postgresql+asyncpg://ironlog:CHANGE_ME@localhost:5432/ironlog

REDIS_URL=redis://:CHANGE_ME@localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ironlog
MINIO_SECRET_KEY=minio_secret_key_min_8_chars
MINIO_USE_SSL=false

# Запросы из браузера: web localhost:3000, admin localhost:3002 (см. .cursorrules / docs)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3002

ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── Dramatiq / worker ──────────────────────────────────────────────────────

RABBITMQ_URL=amqp://ironlog:CHANGE_ME@localhost:5672/ironlog

# ── JWT / авторизация ─────────────────────────────────────────────────────

SECRET_KEY=change_me_to_random_256bit_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=90

# ── Почта (опционально) ────────────────────────────────────────────────────

# SMTP_HOST=
# SMTP_PORT=587
