# ─────────────────────────────────────────────
# IronLog — .gitignore
# ─────────────────────────────────────────────

# ── Env / Secrets ────────────────────────────
# Root and package-level env files (pattern .env excludes name .env anywhere)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.development
.env.test
.env.production
.env.staging

backend/.env
web/.env
web/.env.local
web/.env.production.local
admin/.env
admin/.env.local
admin/.env.production.local

!.env.example
!**/.env.example

*.pem
*.p12

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

.venv/
venv/
env/

.pytest_cache/
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytype/
.pyre/
.pyright/
.basedpyright/
.tox/
.nox/
.uv/

htmlcov/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover
*.py,cover

*.log
pip-log.txt

# ── Node / Next.js ───────────────────────────
node_modules/
.next/
out/
.turbo/
.swc/

*.tsbuildinfo

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

.vercel/

# ── Docker ───────────────────────────────────
docker-compose.override.yml

# ── OS ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ── IDE / editors ────────────────────────────
.idea/
*.swp
*.swo
*.suo
.vscode/settings.json

# ── Uploads / Media ────────────────────────────
backend/uploads/
backend/media/

# ── SQLite (local scratch / experiments) ───
*.sqlite3
*.sqlite

# ── Grafana ──────────────────────────────────
grafana-dashboards/*.bak

# ── Flutter (optional, if mobile/frontend app added) ─
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/build/
frontend/.packages

# ── Jupyter / scratch ────────────────────────
.ipynb_checkpoints/
temp/

# ── Local handoff bundles (keep out of Git) ─
IronLog-handoff.zip
*-handoff.zip

# ── Tests ────────────────────────────────────
.hypothesis/
