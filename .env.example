# ─────────────────────────────────────────────
# IronLog — .env.example
# Скопируй в .env у корня репозитория для docker-compose (интерполяция ${VAR} в compose.yml).
# Для FastAPI см. дополнительно backend/.env.example и env_file сервиса api.
# ─────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────
POSTGRES_PASSWORD=ironlog_secret

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── RabbitMQ ─────────────────────────────────
RABBITMQ_USER=ironlog
RABBITMQ_PASSWORD=rabbitmq_secret

# ── MinIO ────────────────────────────────────
MINIO_ROOT_USER=ironlog
MINIO_ROOT_PASSWORD=minio_secret_key_min_8_chars

# ── FastAPI / JWT ────────────────────────────
SECRET_KEY=change_me_to_random_256bit_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=90

# ── CORS (web localhost:3000, admin localhost:3002; см. backend/.env.example) ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3002

# ── Email (опционально) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=IronLog <noreply@ironlog.app>

# ── Monitoring ───────────────────────────────
PGADMIN_PASSWORD=pgadmin_secret
GRAFANA_PASSWORD=grafana_secret

# ── Environment ──────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
